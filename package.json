{
  "name": "utterlog-bun",
  "version": "1.3.7",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./app/web/*",
    "@shared/*": "./app/shared/*",
    "next/link": "./app/blog/src/shims/link.tsx",
    "next/navigation": "./app/blog/src/shims/navigation.ts",
    "next/script": "./app/blog/src/shims/script.tsx",
    "next/cache": "./app/blog/src/shims/cache.ts",
    "next/headers": "./app/blog/src/shims/headers.ts",
    "next/server": "./app/blog/src/shims/server.ts"
  },
  "workspaces": [
    "app/web",
    "app/admin",
    "app/blog",
    "app/next-shim"
  ],
  "scripts": {
    "dev": "bun run app/server/src/index.ts",
    "server:dev": "bun run app/server/src/index.ts",
    "server:check": "bunx tsc -p app/server/tsconfig.json --noEmit",
    "test:server": "JWT_SECRET=test-secret-for-server-tests bun test app/server/test",
    "build:web": "cd app/web && bun run sync:themes",
    "build:blog-client": "bun build app/web/app/globals.css --outdir app/blog/dist --target browser && bun build app/blog/src/client.tsx --outdir app/blog/dist --target browser --minify --define process.env.NEXT_PUBLIC_API_URL='\"/api/v1\"' --define process.env.NEXT_PUBLIC_SITE_URL='\"\"' --define process.env.INTERNAL_API_URL='\"\"' --define process.env.DEBUG='\"\"' --define process.env.NODE_ENV='\"production\"'",
    "build:admin": "cd app/admin && bun run build"
  },
  "dependencies": {
    "@simplewebauthn/server": "^13.3.2",
    "@simplewebauthn/types": "^12.0.0",
    "hono": "^4.12.27",
    "jose": "^6.2.3",
    "next": "workspace:*",
    "nodemailer": "^9.0.1",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.1",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
  }
}
