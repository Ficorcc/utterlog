# ============================================================
# Utterlog 环境变量模板
# ------------------------------------------------------------
# 复制此文件为 .env 并按需修改：  cp .env.example .env
# Docker 用户：在 docker-compose.yml 中直接改 environment 即可
# ============================================================

# ---- 数据库 ----
# 使用外部 PostgreSQL 时设为 external；deploy.sh 会禁用内置 postgres service。
# UTTERLOG_DB_MODE=external
DB_HOST=postgres
DB_PORT=5432
DB_NAME=utterlog
DB_USER=utterlog
# 留空 — deploy.sh / install.sh 会生成 16 位随机密码写入此处
DB_PASSWORD=
DB_PREFIX=ul_

# ---- API ----
PORT=8080
APP_URL=http://localhost:9260
# 生产公网部署时可设为 true，强制 APP_URL 不能是 localhost/127.0.0.1。
REQUIRE_PUBLIC_APP_URL=false
# 默认只允许 APP_URL 同源访问 API；需要分离前后端域名时填允许的 Origin，多个用逗号分隔。
# CORS_ORIGIN=https://blog.example.com,https://admin.example.com
# 留空 — deploy.sh / install.sh 会生成 48 位随机密钥
JWT_SECRET=

# ---- 对外端口（生产部署用）----
# 仅绑 127.0.0.1，不占用 80/443；nginx/caddy 反代到这里。
# 部署脚本会自动检测端口占用，被占则顺延到下一个可用端口。
UTTERLOG_PORT=9260

# ---- 文件存储（local 或 s3）----
STORAGE_DRIVER=local
UPLOAD_DIR=uploads

# S3/R2 配置（STORAGE_DRIVER=s3 时生效）
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto
S3_PUBLIC_URL=

# ---- Web 前端（Bun SSR，同 app 容器）----
WEB_RENDERER=bun
NEXT_PUBLIC_API_URL=/api/v1
INTERNAL_API_URL=http://127.0.0.1:8080/api/v1

# ---- 源码/资源路径（目录合并迁移用；默认不需要修改）----
# SERVER_ASSETS_DIR=app/server/assets
# SCHEMA_FILE=app/server/assets/schema.sql
# INSTALLER_FAVICON=app/server/assets/installer/favicon.svg
# BUILTIN_LOCALE_DIR=app/server/assets/i18n/locales
# BUILTIN_THEMES_DIR=app/web/themes
# BUILTIN_PLUGINS_DIR=app/web/plugins
# BUILTIN_PUBLIC_THEMES_DIR=app/web/public/themes
# ADMIN_DIST_DIR=app/admin/dist
# LEGACY_PUBLIC_DIR=app/server/assets/public
